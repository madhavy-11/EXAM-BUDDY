# ============================================
# EXAM BUDDY - .gitignore
# Complete with Email Reminders Support
# ============================================

# ============================================
# DATABASE FILES (IMPORTANT!)
# ============================================
*.db
*.sqlite
*.sqlite3
exams.db
exams_backup_*.db
*.db-journal
*.db-wal
*.db-shm

# ============================================
# DATA FILES (User data - DON'T share!)
# ============================================
*.json
!requirements.json
!email_config_example.json    # ✅ ALLOW template file
*.backup
*.bak
exams_old.json
exam_export_*.json

# ============================================
# EMAIL CONFIGURATION (IMPORTANT!)
# ============================================
email_config.json              # ⚠️ NEVER commit this!
email_config.local.json
email_settings.json
.env.email
credentials_email.json

# ============================================
# PYTHON CACHE FILES
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.coverage
htmlcov/
.tox/
*.pyc
*.pyo

# ============================================
# VIRTUAL ENVIRONMENT
# ============================================
venv/
env/
ENV/
.venv
virtualenv/
pyvenv.cfg
venv.bak/
env.bak/

# ============================================
# IDE AND EDITOR FILES
# ============================================
# VS Code
.vscode/
*.code-workspace
.vscode-test/
.vscode/settings.json
.vscode/launch.json

# PyCharm
.idea/
*.iml
.idea_modules/
.idea/*.xml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/
*.atom

# Vim
*.swp
*.swo
*~
*.un~

# Other editors
.vscode/
*.code-workspace

# ============================================
# OPERATING SYSTEM FILES
# ============================================
.DS_Store
Thumbs.db
desktop.ini
*.DS_Store
ehthumbs.db
*.db
*.db-journal

# ============================================
# LOGS AND TEMPORARY FILES
# ============================================
*.log
*.tmp
*.temp
*.pid
*.crash
*.stackdump
logs/
*.log.*

# ============================================
# BACKUP FILES
# ============================================
*.bak
*.old
*.orig
*.rej
*.backup
backup/
backups/
*.backup.*
*.db.backup

# ============================================
# PYTHON DISTRIBUTION
# ============================================
dist/
build/
*.egg-info/
*.egg
MANIFEST
*.whl
*.tar.gz

# ============================================
# TEST COVERAGE
# ============================================
.coverage
htmlcov/
.tox/
.pytest_cache/
coverage.xml
*.cover
.hypothesis/
.tox/

# ============================================
# DEPLOYMENT
# ============================================
*.zip
*.tar.gz
*.7z
package-lock.json
yarn.lock
*.deb
*.rpm
*.msi

# ============================================
# DOCUMENTATION (Keep these)
# ============================================
docs/_build/
docs/build/
docs/api/

# ============================================
# ENVIRONMENT VARIABLES
# ============================================
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test

# ============================================
# SECURITY (VERY IMPORTANT!)
# ============================================
*.pem
*.key
*.crt
*.p12
*.p8
secrets.py
config.py
credentials.json
secrets.json
secret_key.txt

# ============================================
# DATABASE MIGRATIONS
# ============================================
migrations/
alembic/
db_migrations/
*.sql

# ============================================
# SCREENSHOTS (Keep these)
# ============================================
!screenshots/
*.png
*.jpg
*.jpeg
*.gif
*.bmp

# ============================================
# YOUR PROJECT SPECIFIC FILES
# ============================================
exam_schedule_*.txt
exam_schedule_*.json
exported_exams.json
exam_export_*.json
exam_*.txt

# ============================================
# EMAIL RELATED (DOUBLE CHECK)
# ============================================
# ⚠️ IMPORTANT: NEVER commit these!
email_config.json              # Real credentials
email_config.local.json
email_credentials.json
.credentials
.creds

# ✅ OK to commit these:
!email_config_example.json     # Template file (safe)
!email_template.html           # HTML templates (safe)

# ============================================
# MISC
# ============================================
*.orig
*.rej
*.swp
*.swo
*~
*.lock
*.pid
*.session
*.session-journal
.npm
.node_modules

# ============================================
# ADD YOUR CUSTOM IGNORES BELOW THIS LINE
# ============================================
